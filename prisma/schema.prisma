generator client {
  provider = "prisma-client-js"
} 


datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  full_name     String               @db.VarChar(100)
  email         String               @unique @db.VarChar(150)
  phone         String?              @unique @db.VarChar(15)
  password_hash String
  address       String?
  latitude      Decimal?             @db.Decimal(9, 6)
  longitude     Decimal?             @db.Decimal(9, 6)
  created_at    DateTime             @default(now())
  updated_at    DateTime             @default(now())
  orders        Order[]
  reviews       Review[]
  preferences   UserFoodPreference[]

  @@index([email])
  @@map("users")
}

model UserFoodPreference {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String  @db.Uuid
  ingredient_name String? @db.VarChar(100)
  is_allergy      Boolean @default(false)
  is_dislike      Boolean @default(false)
  user            User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_food_preferences")
}

model Restaurant {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String            @db.VarChar(150)
  email         String            @unique @db.VarChar(150)
  password_hash String
  description   String?
  address       String
  city          String?           @db.VarChar(100)
  latitude      Decimal?          @db.Decimal(9, 6)
  longitude     Decimal?          @db.Decimal(9, 6)
  phone         String?           @db.VarChar(15)
  image_url     String?
  is_active     Boolean           @default(true)
  created_at    DateTime          @default(now())
  dishes        Dish[]
  offers        Offer[]
  orders        Order[]
  reviews       Review[]
  qr_code       RestaurantQRCode?
  table_slots   TableSlot[]
  cuisine       String[]          @default([])

  @@index([latitude, longitude], map: "idx_restaurant_location")
  @@index([email])
  @@map("restaurants")
}

model RestaurantQRCode {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurant_id String     @unique @db.Uuid
  qr_code_url   String
  created_at    DateTime   @default(now())
  restaurant    Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)

  @@map("restaurant_qr_codes")
}

model TableSlot {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurant_id String     @db.Uuid
  time          String     @db.VarChar(20)
  total_seats   Int        @default(20)
  booked_seats  Int        @default(0)
  restaurant    Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)

  @@index([restaurant_id], map: "idx_table_slots_restaurant")
  @@map("table_slots")
}

model Dish {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurant_id   String           @db.Uuid
  name            String           @db.VarChar(150)
  description     String?
  cooking_method  String?
  calories        Int?
  price           Decimal?         @db.Decimal(10, 2)
  recommended_for String?
  image_url       String?
  category        String?          @db.VarChar(100)
  is_available    Boolean          @default(true)
  ingredients     DishIngredient[]
  restaurant      Restaurant       @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  order_items     OrderItem[]
  reviews         Review[]

  @@index([restaurant_id], map: "idx_dishes_restaurant")
  @@map("dishes")
}

model Ingredient {
  id     String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name   String           @unique @db.VarChar(100)
  dishes DishIngredient[]

  @@map("ingredients")
}

model DishIngredient {
  dish_id       String     @db.Uuid
  ingredient_id String     @db.Uuid
  is_allergen   Boolean    @default(false)
  dish          Dish       @relation(fields: [dish_id], references: [id], onDelete: Cascade)
  ingredient    Ingredient @relation(fields: [ingredient_id], references: [id], onDelete: Cascade)

  @@id([dish_id, ingredient_id])
  @@map("dish_ingredients")
}

model Offer {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurant_id    String     @db.Uuid
  title            String?    @db.VarChar(150)
  discount_percent Int?
  valid_from       DateTime?  @db.Date
  valid_to         DateTime?  @db.Date
  is_active        Boolean    @default(true)
  restaurant       Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)

  @@map("offers")
}

model Order {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String?      @db.Uuid
  restaurant_id  String?      @db.Uuid
  dining_option  DiningType?
  scheduled_time DateTime?
  status         OrderStatus? @default(PENDING)
  created_at     DateTime     @default(now())
  order_items    OrderItem[]
  restaurant     Restaurant?  @relation(fields: [restaurant_id], references: [id])
  user           User?        @relation(fields: [user_id], references: [id])

  @@map("orders")
}

model OrderItem {
  order_id String @db.Uuid
  dish_id  String @db.Uuid
  quantity Int?   @default(1)
  dish     Dish   @relation(fields: [dish_id], references: [id])
  order    Order  @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@id([order_id, dish_id])
  @@map("order_items")
}

model Review {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String?    @db.Uuid
  dish_id      String?    @db.Uuid
  restaurant_id String?   @db.Uuid
  rating       Int?
  comment      String?
  avatar       String?
  created_at   DateTime   @default(now())
  dish         Dish?      @relation(fields: [dish_id], references: [id])
  restaurant   Restaurant? @relation(fields: [restaurant_id], references: [id])
  user         User?      @relation(fields: [user_id], references: [id])

  @@map("reviews")
}

enum UserRole {
  CUSTOMER
  RESTAURANT_ADMIN
}

enum DiningType {
  DINE_IN
  PICKUP
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  CANCELLED
  COMPLETED
}

model Vendor {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @db.VarChar(150)
  description  String?
  critic_score Float?
  food         String[] @default([])
  image_url    String?
  tags         String[] @default([])
  location     String?  @db.VarChar(255)
  price_range  String?  @db.VarChar(10)
  created_at   DateTime @default(now())

  @@index([name])
  @@map("vendors")
}